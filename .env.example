# Copy to .env.local for local development. Set the real values in the
# Netlify UI (Site settings > Environment variables). Never commit secrets.

# Canonical site URL (defaults to the production domain if unset).
NEXT_PUBLIC_SITE_URL=https://lincs-staycation-guide.co.uk

# Google Analytics 4 measurement ID (G-XXXXXXXXXX).
# Analytics only load after the visitor accepts the cookie banner.
NEXT_PUBLIC_GA4_ID=

# CJ Affiliate (Commission Junction) — Booking.com UK programme.
# Defaults are baked into src/lib/affiliate.ts (PID 101754317 =
# "Lincs Staycation Guide" website property, link 15734754 = Booking.com UK
# evergreen deep link); set these only to override per-environment.
NEXT_PUBLIC_CJ_PID=
NEXT_PUBLIC_CJ_BOOKING_LINK_ID=

# Form email delivery (Resend - https://resend.com).
# The sender domain must be verified in Resend first.
# While unset, the contact and business forms return a clear "temporarily
# unavailable" message instead of pretending to send.
RESEND_API_KEY=
CONTACT_EMAIL=hello@lincs-staycation-guide.co.uk
CONTACT_FROM_EMAIL=forms@lincs-staycation-guide.co.uk
