{
  "name": "lincs-staycation-guide",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "content:audit": "node scripts/audit-content-quality.mjs",
    "content:editorial-audit": "node scripts/audit-editorial-readiness.mjs",
    "content:editorial-strict": "node scripts/check-editorial-quality.mjs",
    "check:editorial-audit:self": "node scripts/audit-editorial-readiness.mjs --self-check",
    "check:editorial-quality": "npm run content:editorial-strict",
    "audit:sources": "node scripts/audit-listing-sources.mjs",
    "qa:static": "node scripts/audit-static-routes.mjs",
    "check:site-quality": "npm run content:audit && npm run content:editorial-audit && npm run qa:static",
    "qa": "npm run lint && npm run typecheck && npm run check:site-quality && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run build && node scripts/run-playwright-e2e.mjs --reporter=line --workers=1"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
